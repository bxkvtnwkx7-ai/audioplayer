local tape = peripheral.find("tape_drive")

local station = "lofi"
local i = 0

tape.stop()
tape.seek(-tape.getPosition())

while true do
    local url = "http://3.219.204.139:3000/radio/" .. station .. "/" ..
        string.format("%04d", i) .. ".bin"

    local h = http.get(url)
    if not h then
        i = 0 -- loop station
    else
        local data = h.readAll()
        h.close()

        tape.write(data)

        i = i + 1
    end
end
